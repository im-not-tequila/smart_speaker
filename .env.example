# Скопируйте в .env и заполните своими значениями:
#   cp .env.example .env

# --- Gemini (нормализация голосовых запросов перед поиском) ---
# Без ключа нормализация отключена, поиск работает по сырому тексту STT.
GEMINI_API_KEY=

# --- SoundCloud API ---
# OAuth-токен из браузера (Network → Authorization, без префикса «OAuth »).
SOUNDCLOUD_OAUTH_TOKEN=
# client_id из запросов к api-v2.soundcloud.com
SOUNDCLOUD_CLIENT_ID=
# user_id из параметров search (формат XXXXX-XXXXX-XXXXX-XXXXXX)
SOUNDCLOUD_USER_ID=
# sc_a_id из параметров search
SOUNDCLOUD_SC_A_ID=
# Необязательно — версия приложения и локаль из запросов SoundCloud
SOUNDCLOUD_APP_VERSION=1759936298
SOUNDCLOUD_APP_LOCALE=en
